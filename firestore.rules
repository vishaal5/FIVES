rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(playerId) { return isSignedIn() && request.auth.uid == playerId; }

    // --- Validation Functions ---
    
    function isValidGame(data) {
      return data.hostId is string 
        && data.status in ['waiting', 'playing', 'round_over', 'game_over']
        && data.round is number
        && data.maxRounds is number
        && data.turn is number
        && (data.pretendJokerRank == null || data.pretendJokerRank is string)
        && data.openPile is list
        && data.deckCount is number
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidPlayer(data) {
      return data.name is string && data.name.size() <= 50
        && data.score is number
        && data.isReady is bool
        && data.hasCalled is bool
        && data.hand is list;
    }

    // --- Rules ---

    match /games/{gameId} {
      allow get: if isSignedIn();
      allow list: if false; // No public listing of games
      
      allow create: if isSignedIn() 
        && isValidId(gameId) 
        && isValidGame(incoming())
        && incoming().hostId == request.auth.uid;
      
      allow update: if isSignedIn()
        && (
          // Host actions (starting game, changing status)
          (existing().hostId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasAny(['status', 'round', 'turn', 'pretendJokerRank', 'openPile', 'deckCount', 'updatedAt']))
          ||
          // Generic player actions (making moves, taking cards)
          (incoming().diff(existing()).affectedKeys().hasAny(['turn', 'openPile', 'deckCount', 'updatedAt']))
        )
        && incoming().updatedAt == request.time;
    }

    match /games/{gameId}/players/{playerId} {
      allow read: if isSignedIn();
      
      allow create: if isOwner(playerId) 
        && isValidPlayer(incoming())
        && incoming().score == 0;
        
      allow update: if (isOwner(playerId) || (isSignedIn() && get(/databases/$(database)/documents/games/$(gameId)).data.hostId == request.auth.uid))
        && isValidPlayer(incoming())
        && (
          isOwner(playerId) ? 
            incoming().diff(existing()).affectedKeys().hasOnly(['name', 'isReady', 'hand', 'hasCalled', 'score']) 
            : 
            incoming().diff(existing()).affectedKeys().hasOnly(['hand', 'score', 'hasCalled']) // Host can deal cards or update scores
        );
    }
  }
}
