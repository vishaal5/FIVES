{
  "entities": {
    "Game": {
      "title": "Fives Game Session",
      "description": "Represents an active or pending FIVES game session",
      "type": "object",
      "properties": {
        "hostId": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "playing", "round_over", "game_over"] },
        "round": { "type": "number" },
        "maxRounds": { "type": "number" },
        "turn": { "type": "number" },
        "pretendJokerRank": { "type": "string" },
        "openPile": { "type": "array" },
        "deckCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["hostId", "status", "createdAt"]
    },
    "Player": {
      "title": "Player in Session",
      "description": "Represents a player's private and public state in a game",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "hand": { "type": "array" },
        "score": { "type": "number" },
        "isReady": { "type": "boolean" },
        "hasCalled": { "type": "boolean" }
      },
      "required": ["name", "score"]
    }
  },
  "firestore": {
    "/games/{gameId}": {
      "schema": "Game",
      "description": "Core game session data"
    },
    "/games/{gameId}/players/{playerId}": {
      "schema": "Player",
      "description": "Player state within a specific game"
    }
  }
}
