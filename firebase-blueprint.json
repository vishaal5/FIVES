{
  "entities": {
    "Room": {
      "title": "Room",
      "description": "A game room lobby",
      "type": "object",
      "properties": {
        "roomName": { "type": "string" },
        "hostId": { "type": "string" },
        "status": { "type": "string", "enum": ["lobby", "playing", "round_over", "game_over"] },
        "numPlayers": { "type": "number" },
        "maxGames": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["roomName", "hostId", "status", "numPlayers", "maxGames"]
    },
    "Player": {
      "title": "Player",
      "description": "A player in a room",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "score": { "type": "number" },
        "isConfirmed": { "type": "boolean" },
        "isHost": { "type": "boolean" },
        "hand": { "type": "array", "items": { "type": "object" } },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "score", "isConfirmed", "isHost"]
    },
    "GameState": {
      "title": "GameState",
      "description": "The current state of the game",
      "type": "object",
      "properties": {
        "deck": { "type": "array" },
        "discardPile": { "type": "array" },
        "openCard": { "type": "object" },
        "jokerCard": { "type": "object" },
        "jokerRank": { "type": "string" },
        "currentPlayerIndex": { "type": "number" },
        "startingPlayerIndex": { "type": "number" },
        "status": { "type": "string" },
        "roundCount": { "type": "number" },
        "gameCount": { "type": "number" },
        "message": { "type": "string" },
        "availableCardAtTurnStart": { "type": "object" }
      }
    }
  },
  "firestore": {
    "rooms/{roomId}": {
      "schema": "Room",
      "description": "Main room document"
    },
    "rooms/{roomId}/players/{playerId}": {
      "schema": "Player",
      "description": "Individual player data"
    },
    "rooms/{roomId}/state/current": {
      "schema": "GameState",
      "description": "Real-time game state"
    }
  }
}
